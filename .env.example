# 이메일 설정 (Gmail 예시)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password   # Gmail 앱 비밀번호
SENDER_NAME=한씨막국수

# 마감 리포트 수신 이메일 (사장님 이메일)
OWNER_EMAIL=owner@example.com

# 자동 마감 시간 (24시간 기준, 기본값: 17:00)
CLOSE_HOUR=17
CLOSE_MIN=0

# 공급업체 이메일 — 형식: 업체명:이메일
SUPPLIER_면류=면류업체:noodle@supplier.com
SUPPLIER_육류=정육업체:meat@supplier.com
SUPPLIER_수산=수산업체:fish@supplier.com
SUPPLIER_채소=채소업체:veg@supplier.com
SUPPLIER_기타=식자재마트:etc@supplier.com
ANTHROPIC_API_KEY=your_anthropic_api_key
