# 이메일 설정 (Gmail 예시)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password   # Gmail은 앱 비밀번호 사용
SENDER_NAME=우리식당

# 마감 리포트 수신 이메일 (사장님 이메일)
OWNER_EMAIL=owner@example.com

# 자동 마감 시간 (24시간 기준, 기본값: 17:00)
CLOSE_HOUR=17
CLOSE_MIN=0

# 공급업체 이메일 — 형식: 업체명:이메일
SUPPLIER_육류=고기나라:meat@supplier.com
SUPPLIER_채소=싱싱채소:veg@supplier.com
SUPPLIER_곡류=쌀집:grain@supplier.com
SUPPLIER_기타=식자재마트:etc@supplier.com
